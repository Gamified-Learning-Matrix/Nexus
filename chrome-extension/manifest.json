{
  "manifest_version": 3,
  "name": "Gulf Nexus Command Center",
  "version": "1.0.0",
  "description": "Unified Command Center for the Gulf Nexus ecosystem — gamification, GitHub, DNS, authentication, network defense, and Sovereign Matrix administration.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gulf Nexus Command Center",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.github.com/*",
    "https://api.github.com/*",
    "https://*.firebaseio.com/*",
    "https://*.firebase.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://dns.google/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
